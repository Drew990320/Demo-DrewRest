# Dependencies
node_modules/
# Expo export en LaReserva (rutas con "node_modules" o "build" en el nombre, no son npm)
!LaReserva/web/assets/
!LaReserva/web/assets/**
!LaReserva/web/assets/**/build/**

# Build / cache
dist/
build/
*.tsbuildinfo
.cache/
*.zip

# Env
.env
.env.*.local

# Licencias: clave privada y archivos emitidos (nunca empaquetar ni subir)
scripts/license-keys/private.pem
license.key
**/license.key

# Logs & OS
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# Test
coverage/

# NestJS
services/api/coverage/

# Paquete on-prem (generar con la-reserva:empaquetar-api)
LaReserva/api/dist/
LaReserva/api/node_modules/
LaReserva/api/vendor/
LaReserva/web/web-port.txt

# Expo / React Native
apps/mobile/.expo/
apps/mobile/dist/
apps/mobile/web-build/
apps/mobile/*.jks
apps/mobile/*.p8
apps/mobile/*.p12
apps/mobile/*.key
apps/mobile/*.mobileprovision
apps/mobile/.metro-health-check*

# IDE
.idea/
.vscode/*
!.vscode/extensions.json
