{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_LOCAL_MODE": "false",
        "EXPO_PUBLIC_API_URL": "http://192.168.1.7:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_LOCAL_MODE": "false",
        "EXPO_PUBLIC_API_URL": "http://192.168.1.7:3000"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
