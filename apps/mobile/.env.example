# URL base del API (sin barra final).
# - Para Expo Web en el PC: http://127.0.0.1:3000 está bien (config.ts ajusta según el host).
# - localhost en el manifest NO se aplica a la app nativa: se usa `extra.apiUrl` del app.json o la IP inferida del bundle de Metro en dev.
# - Para forzar IP en todos los entornos: ej. http://192.168.1.7:3000 (misma red Wi‑Fi que los celulares).
# Tras cambiar: `npx expo start -c`
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000

# true = datos en memoria/local sin backend (desarrollo offline). false = usar el API real.
EXPO_PUBLIC_LOCAL_MODE=false

# Opcional: forzar URL del API solo en navegador (sobrescribe la lógica de config.ts).
# No uses http://127.0.0.1:3000 aquí si abres el front desde el móvil: en el teléfono eso es el propio dispositivo.
# En LAN, config.ts usa el mismo host que la barra de direcciones (IP del PC) + puerto del API abajo.
# EXPO_PUBLIC_API_URL_WEB=http://192.168.1.7:3000

# Opcional: desactivar Socket.IO (p. ej. si el servidor no tiene WebSockets).
# EXPO_PUBLIC_DISABLE_SOCKET=false
