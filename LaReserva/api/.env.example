DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/la_reserva?schema=public"
JWT_SECRET="cambiar-por-secreto-largo-en-produccion"

# API HTTP + Socket.IO. 0.0.0.0 = aceptar conexiones desde la red local (celulares vía IP del PC).
PORT=3000
HOST=0.0.0.0

# Impresora POS 58 mm (ESC/POS, ej. Jaltech 58M) en el PC del restaurante.
PRINTER_ENABLED=true
# Varios destinos separados por coma (prueba en orden). Ejemplos:
#   printer:POS-58              — impresora USB por nombre en Windows
#   COM3                        — Bluetooth emparejado (puerto serie)
PRINTER_INTERFACE=printer:POS-58,COM3
PRINTER_WIDTH=32
PRINTER_BAUD_RATE=9600
# Segundos de margen entre tickets (corte manual). 0 = solo cola, sin pausa extra.
PRINTER_JOB_COOLDOWN_MS=10000
