generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstadoMesa {
  libre
  ocupada
  reservada
}

enum EstadoPedido {
  abierto
  en_cocina
  facturado
}

enum TipoPersonalizacion {
  omitir_ingrediente
  aderezo
}

enum MetodoPago {
  efectivo
  tarjeta
  transferencia
}

enum MetodoDevolucionExceso {
  efectivo
  transferencia
}

enum TipoMovimientoCaja {
  devolucion_exceso_transferencia
  entrada_manual
  salida_manual
  pago_domicilio
  pago_mesero
}

enum TipoRegistroBeneficioMesero {
  soda_almuerzo
  pago_turno
}

enum EstadoCredito {
  abierto
  pagado
}

enum TipoMovInventario {
  entrada
  consumo
  ajuste
}

enum ModoServicio {
  en_mesa
  para_llevar
}

enum TipoProteina {
  ninguno
  pollo
  res
  cerdo
  otro
}

enum PrioridadCocina {
  alta
  baja
}

enum TipoEventoPedido {
  detalle_agregado
  detalle_eliminado
  cantidad_actualizada
  pendiente_anulado_cierre
  cuota_plan_omitida
  cobro_reabierto
  /// Anula una sola tanda (factura o grupo mixto), no todos los cobros del pedido.
  cobro_tanda_revertida
}

enum TipoDelegacionMesero {
  cierre_con_anulacion
}

model Rol {
  idRol       Int       @id @default(autoincrement()) @map("id_rol")
  nombre      String    @unique @db.VarChar(50)
  descripcion String?   @db.VarChar(255)
  usuarios    Usuario[]

  @@map("rol")
}

model Usuario {
  idUsuario    Int      @id @default(autoincrement()) @map("id_usuario")
  idRol        Int      @map("id_rol")
  nombre       String   @db.VarChar(100)
  apellido     String   @db.VarChar(100)
  email        String   @unique @db.VarChar(150)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  passwordCambiadoEn DateTime? @map("password_cambiado_en")
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now()) @map("creado_en")
  rol          Rol      @relation(fields: [idRol], references: [idRol])
  pedidos           Pedido[]
  facturas          Factura[]
  historialPedidos  PedidoHistorial[]
  beneficiosMesero      RegistroBeneficioMesero[] @relation("BeneficioMesero")
  beneficiosRegistrados RegistroBeneficioMesero[] @relation("BeneficioRegistradoPor")
  delegacionesMeseroTurno       DelegacionMeseroTurno[] @relation("DelegacionMesero")
  delegacionesMeseroRegistradas DelegacionMeseroTurno[] @relation("DelegacionRegistradaPor")
  movimientosCaja               MovimientoCaja[]
  cuentasCredito                CuentaCredito[]

  @@map("usuario")
}

model Mesa {
  idMesa              Int        @id @default(autoincrement()) @map("id_mesa")
  numero              Int        @unique
  capacidad           Int
  estado              EstadoMesa @default(libre)
  disponibleLunes     Boolean    @default(true) @map("disponible_lunes")
  disponibleMartes    Boolean    @default(true) @map("disponible_martes")
  disponibleMiercoles Boolean    @default(true) @map("disponible_miercoles")
  disponibleJueves    Boolean    @default(true) @map("disponible_jueves")
  disponibleViernes   Boolean    @default(true) @map("disponible_viernes")
  disponibleSabado    Boolean    @default(true) @map("disponible_sabado")
  disponibleDomingo   Boolean    @default(true) @map("disponible_domingo")
  pedidos             Pedido[]

  @@map("mesa")
}

enum TipoLineaCocinaCat {
  plato
  entrada
  adicional

  @@map("tipo_linea_cocina_cat")
}

model Categoria {
  idCategoria              Int                  @id @default(autoincrement()) @map("id_categoria")
  nombre                   String               @db.VarChar(100)
  disponibleLunes          Boolean              @default(true) @map("disponible_lunes")
  disponibleMartes         Boolean              @default(true) @map("disponible_martes")
  disponibleMiercoles      Boolean              @default(true) @map("disponible_miercoles")
  disponibleJueves         Boolean              @default(true) @map("disponible_jueves")
  disponibleViernes        Boolean              @default(true) @map("disponible_viernes")
  disponibleSabado         Boolean              @default(true) @map("disponible_sabado")
  disponibleDomingo        Boolean              @default(true) @map("disponible_domingo")
  esBebida                 Boolean              @default(false) @map("es_bebida")
  cobraEmpaqueParaLlevar   Boolean              @default(false) @map("cobra_empaque_para_llevar")
  participaDescuentoSopas  Boolean              @default(false) @map("participa_descuento_sopas")
  esLineaEmpaque           Boolean              @default(false) @map("es_linea_empaque")
  visibleEnMostrador       Boolean              @default(false) @map("visible_en_mostrador")
  tipoLineaCocinaDefault   TipoLineaCocinaCat   @default(plato) @map("tipo_linea_cocina_default")
  esPlatoPrincipalDefault  Boolean              @default(false) @map("es_plato_principal_default")
  /// Icono Material Community para la barra de categorías del menú (null = inferir por nombre).
  iconoMenu                String?              @map("icono_menu") @db.VarChar(80)
  /// Oculta toda la categoría del menú (reversible); los días definen visibilidad cuando está activa.
  activo                   Boolean              @default(true)
  productos                Producto[]

  @@map("categoria")
}

model Producto {
  idProducto         Int                     @id @default(autoincrement()) @map("id_producto")
  idCategoria        Int                     @map("id_categoria")
  nombre             String                  @db.VarChar(150)
  descripcion        String?                 @db.Text
  precio             Decimal                 @db.Decimal(10, 2)
  activo             Boolean                 @default(true)
  esPlatoPrincipal   Boolean                 @default(false) @map("es_plato_principal")
  esEmpacable        Boolean                 @default(false) @map("es_empacable")
  /// Línea automática de cocina: 1 por comensal, sin cobro (no aparece en menú).
  esAcompanamientoMazorca Boolean            @default(false) @map("es_acompanamiento_mazorca")
  /// Línea cobrable por cuota omitida en reparto (no menú, no cocina).
  esCuotaPendienteReparto Boolean            @default(false) @map("es_cuota_pendiente_reparto")
  tipoProteina       TipoProteina            @default(ninguno) @map("tipo_proteina")
  /// Solo aplica en categorías bebida: control de unidades pedibles.
  controlStock       Boolean                 @default(false) @map("control_stock")
  stockDisponible    Int                     @default(0) @map("stock_disponible")
  /// Si true, no aparece en menú al llegar a 0; si false, se muestra como agotado.
  ocultarSinStock    Boolean                 @default(true) @map("ocultar_sin_stock")
  categoria          Categoria               @relation(fields: [idCategoria], references: [idCategoria])
  detalles           DetallePedido[]
  opciones                 PersonalizacionOpcion[]
  configOperativaMazorca   ConfigOperativa[]       @relation("ProductoMazorcaConfig")
  configOperativaSoda      ConfigOperativa[]       @relation("ProductoSodaAlmuerzoConfig")
  configOperativaCuotaPendiente ConfigOperativa[]  @relation("ProductoCuotaPendienteConfig")
  registrosBeneficioMesero RegistroBeneficioMesero[]

  @@map("producto")
}

model PersonalizacionOpcion {
  idOpcion    Int                 @id @default(autoincrement()) @map("id_opcion")
  idProducto  Int                 @map("id_producto")
  tipo        TipoPersonalizacion
  descripcion String              @db.VarChar(150)
  producto    Producto            @relation(fields: [idProducto], references: [idProducto], onDelete: Cascade)
  detPers     DetPersonalizacion[]

  @@index([idProducto])
  @@map("personalizacion_opcion")
}

model Pedido {
  idPedido                   Int               @id @default(autoincrement()) @map("id_pedido")
  idMesa                     Int               @map("id_mesa")
  idUsuario                  Int               @map("id_usuario")
  estado                     EstadoPedido      @default(abierto)
  modoServicio               ModoServicio      @default(en_mesa) @map("modo_servicio")
  numComensales              Int               @map("num_comensales")
  creadoEn                   DateTime          @default(now()) @map("creado_en")
  cerradoEn                  DateTime?         @map("cerrado_en")
  prioridadCocinaOverride    PrioridadCocina?  @map("prioridad_cocina_override")
  /// Cliente camionero (mulero): aplica descuento por plato principal si la regla global está activa.
  clienteMulero                Boolean           @default(false) @map("cliente_mulero")
  /// Etiquetas de promoción activas en el pedido (ids del catálogo en config_descuento).
  etiquetasPromocion           Json              @default("[]") @map("etiquetas_promocion")
  mesa                       Mesa              @relation(fields: [idMesa], references: [idMesa])
  usuario                    Usuario           @relation(fields: [idUsuario], references: [idUsuario])
  detalles                   DetallePedido[]
  facturas                   Factura[]
  movimientosCaja            MovimientoCaja[]
  movsInventario            MovInventario[]
  historial                  PedidoHistorial[]
  cuentasCredito             CuentaCredito[]

  @@index([idMesa, estado])
  @@index([estado, creadoEn])
  @@index([idUsuario, estado])
  @@map("pedido")
}

// detalleJson: líneas afectadas, cantidades, nombres (estructura por tipo de evento).
model PedidoHistorial {
  idHistorial Int              @id @default(autoincrement()) @map("id_historial")
  idPedido    Int              @map("id_pedido")
  idUsuario   Int              @map("id_usuario")
  tipo        TipoEventoPedido
  detalleJson Json?            @map("detalle_json")
  creadoEn    DateTime         @default(now()) @map("creado_en")
  pedido      Pedido           @relation(fields: [idPedido], references: [idPedido], onDelete: Cascade)
  usuario     Usuario          @relation(fields: [idUsuario], references: [idUsuario])

  @@index([idPedido])
  @@map("pedido_historial")
}

model DetallePedido {
  idDetalle         Int                  @id @default(autoincrement()) @map("id_detalle")
  idPedido          Int                  @map("id_pedido")
  idProducto        Int                  @map("id_producto")
  idDetallePadre    Int?                 @map("id_detalle_padre")
  cantidad          Int                  @default(1)
  precioUnitario    Decimal              @map("precio_unitario") @db.Decimal(10, 2)
  notaCocina        String?              @map("nota_cocina") @db.Text
  listoCocina       Boolean              @default(false) @map("listo_cocina")
  listoParaRecoger  Boolean              @default(false) @map("listo_para_recoger")
  enviadoCocina     Boolean              @default(false) @map("enviado_cocina")
  idFactura         Int?                 @map("id_factura")
  pedido            Pedido               @relation(fields: [idPedido], references: [idPedido], onDelete: Cascade)
  producto          Producto             @relation(fields: [idProducto], references: [idProducto])
  detallePadre      DetallePedido?       @relation("DetalleEmpaque", fields: [idDetallePadre], references: [idDetalle], onDelete: Cascade)
  empaquesAsociados DetallePedido[]      @relation("DetalleEmpaque")
  personalizaciones DetPersonalizacion[]
  factura           Factura?             @relation(fields: [idFactura], references: [idFactura])

  @@index([idPedido])
  @@index([idDetallePadre])
  @@index([idFactura])
  @@map("detalle_pedido")
}

model DetPersonalizacion {
  idDetPers Int                   @id @default(autoincrement()) @map("id_det_pers")
  idDetalle Int                   @map("id_detalle")
  idOpcion  Int                   @map("id_opcion")
  detalle   DetallePedido         @relation(fields: [idDetalle], references: [idDetalle], onDelete: Cascade)
  opcion    PersonalizacionOpcion @relation(fields: [idOpcion], references: [idOpcion])

  @@index([idDetalle])
  @@map("det_personalizacion")
}

model Factura {
  idFactura         Int        @id @default(autoincrement()) @map("id_factura")
  idPedido          Int        @map("id_pedido")
  idUsuario         Int        @map("id_usuario")
  subtotal          Decimal    @db.Decimal(10, 2)
  descuentoSopas        Decimal    @default(0) @map("descuento_sopas") @db.Decimal(10, 2)
  descuentoMuleros      Decimal    @default(0) @map("descuento_muleros") @db.Decimal(10, 2)
  descuentoPromociones  Decimal    @default(0) @map("descuento_promociones") @db.Decimal(10, 2)
  total             Decimal    @db.Decimal(10, 2)
  metodoPago        MetodoPago @map("metodo_pago")
  emitidaEn         DateTime   @default(now()) @map("emitida_en")
  esParcial         Boolean    @default(false) @map("es_parcial")
  /// Persona del plan de cobro (1-based); varias facturas pueden compartir índice (pago mixto).
  personaPlanIndice Int?       @map("persona_plan_indice")
  /// true = cuota sobre el total (modo por personas); false = ítems asignados (combinado/platos).
  planPersonasSobreTotal Boolean @default(false) @map("plan_personas_sobre_total")
  /// true = cuota sobre ítems marcados (+/−) en modo combinado; ticket muestra selección como referencia.
  planCombinadoSobreSeleccion Boolean @default(false) @map("plan_combinado_sobre_seleccion")
  /// Snapshot [{id_detalle,cantidad}] de la selección combinada (referencia en ticket).
  planSeleccionReferencia Json? @map("plan_seleccion_referencia")
  /// Identificador común de un cobro mixto (efectivo + transferencia en la misma operación).
  cobroMixtoGrupo   Int?       @map("cobro_mixto_grupo")
  /// Vuelto / exceso de cobro (efectivo, transferencia, domicilio, mesero).
  detalleExcesoCobro Json?     @map("detalle_exceso_cobro")
  pedido            Pedido     @relation(fields: [idPedido], references: [idPedido])
  usuario           Usuario    @relation(fields: [idUsuario], references: [idUsuario])
  detalles          DetallePedido[]
  movimientosCaja   MovimientoCaja[]
  cuentaCredito     CuentaCredito?

  @@index([idPedido])
  @@index([emitidaEn])
  @@map("factura")
}

model CuentaCredito {
  idCredito      Int           @id @default(autoincrement()) @map("id_credito")
  idPedido       Int           @map("id_pedido")
  idFactura      Int?          @unique @map("id_factura")
  nombreCliente  String        @map("nombre_cliente") @db.VarChar(120)
  telefono       String?       @db.VarChar(40)
  montoTotal     Decimal       @map("monto_total") @db.Decimal(10, 2)
  saldoPendiente Decimal       @map("saldo_pendiente") @db.Decimal(10, 2)
  notas          String?       @db.VarChar(500)
  estado         EstadoCredito @default(abierto)
  creadoEn       DateTime      @default(now()) @map("creado_en")
  pagadoEn       DateTime?     @map("pagado_en")
  idUsuario      Int           @map("id_usuario")
  pedido         Pedido        @relation(fields: [idPedido], references: [idPedido])
  factura        Factura?      @relation(fields: [idFactura], references: [idFactura])
  usuario        Usuario       @relation(fields: [idUsuario], references: [idUsuario])

  @@index([estado, creadoEn])
  @@map("cuenta_credito")
}

/// Reglas globales de descuento en facturación (singleton id = 1).
model ConfigDescuento {
  id                    Int      @id @default(1)
  sopasActivo           Boolean  @default(false) @map("sopas_activo")
  sopasMontoPorUnidad   Decimal  @default(0) @map("sopas_monto_por_unidad") @db.Decimal(10, 2)
  sopasMinUnidades      Int      @default(2) @map("sopas_min_unidades")
  mulerosActivo         Boolean  @default(false) @map("muleros_activo")
  mulerosMontoPorUnidad Decimal  @default(0) @map("muleros_monto_por_unidad") @db.Decimal(10, 2)
  mulerosMinPlatosPrincipales Int @default(1) @map("muleros_min_platos_principales")
  umbralSubtotalOtros   Decimal  @default(50000) @map("umbral_subtotal_otros") @db.Decimal(12, 2)
  reglasPromocion       Json     @default("[]") @map("reglas_promocion")
  etiquetasPedido       Json     @default("[]") @map("etiquetas_pedido")
  actualizadoEn         DateTime @updatedAt @map("actualizado_en")

  @@map("config_descuento")
}

/// Ajustes operativos del restaurante (singleton id = 1).
model ConfigOperativa {
  id                      Int      @id @default(1)
  precioEmpaqueParaLlevar Decimal  @default(1000) @map("precio_empaque_para_llevar") @db.Decimal(10, 2)
  mazorcaActiva           Boolean  @default(false) @map("mazorca_activa")
  idProductoMazorca       Int?     @map("id_producto_mazorca")
  numeroMesaParaLlevar    Int      @default(98) @map("numero_mesa_para_llevar")
  numeroMesaMostrador     Int      @default(99) @map("numero_mesa_mostrador")
  etiquetaParaLlevar      String   @default("Pedidos para llevar") @map("etiqueta_para_llevar") @db.VarChar(80)
  etiquetaMostrador       String   @default("Mostrador") @map("etiqueta_mostrador") @db.VarChar(80)
  mostradorActivo         Boolean  @default(true) @map("mostrador_activo")
  paraLlevarActivo        Boolean  @default(true) @map("para_llevar_activo")
  beneficioSodaAlmuerzoActivo Boolean @default(false) @map("beneficio_soda_almuerzo_activo")
  idProductoSodaAlmuerzo  Int?     @map("id_producto_soda_almuerzo")
  sodaAlmuerzoDescontarStock Boolean @default(true) @map("soda_almuerzo_descontar_stock")
  idProductoCuotaPendiente Int?     @map("id_producto_cuota_pendiente")
  actualizadoEn           DateTime @updatedAt @map("actualizado_en")
  productoMazorca         Producto? @relation("ProductoMazorcaConfig", fields: [idProductoMazorca], references: [idProducto], onDelete: SetNull)
  productoSodaAlmuerzo    Producto? @relation("ProductoSodaAlmuerzoConfig", fields: [idProductoSodaAlmuerzo], references: [idProducto], onDelete: SetNull)
  productoCuotaPendiente  Producto? @relation("ProductoCuotaPendienteConfig", fields: [idProductoCuotaPendiente], references: [idProducto], onDelete: SetNull)

  @@map("config_operativa")
}

/// Registro de beneficios / pagos por turno del mesero (soda almuerzo, pago, etc.).
model RegistroBeneficioMesero {
  idRegistro        Int                         @id @default(autoincrement()) @map("id_registro")
  fecha             DateTime                    @db.Date @map("fecha")
  idUsuario         Int                         @map("id_usuario")
  tipo              TipoRegistroBeneficioMesero @map("tipo")
  monto             Decimal?                    @db.Decimal(12, 2)
  idProducto        Int?                        @map("id_producto")
  cantidad          Int                         @default(1)
  descontoStock     Boolean                     @default(false) @map("desconto_stock")
  notas             String?                     @db.Text
  idUsuarioRegistro Int                         @map("id_usuario_registro")
  creadoEn          DateTime                    @default(now()) @map("creado_en")
  mesero            Usuario                     @relation("BeneficioMesero", fields: [idUsuario], references: [idUsuario])
  registradoPor     Usuario                     @relation("BeneficioRegistradoPor", fields: [idUsuarioRegistro], references: [idUsuario])
  producto          Producto?                   @relation(fields: [idProducto], references: [idProducto], onDelete: SetNull)

  @@unique([fecha, idUsuario, tipo])
  @@index([fecha])
  @@map("registro_beneficio_mesero")
}

/// Identidad, textos y módulos del restaurante (singleton id = 1).
model ConfigRestaurante {
  id                         Int      @id @default(1)
  nombreComercial            String   @default("Restaurante") @map("nombre_comercial") @db.VarChar(120)
  telefono                   String?  @db.VarChar(40)
  direccion                  String?  @db.VarChar(255)
  dominioEmailInterno        String   @default("restaurant.local") @map("dominio_email_interno") @db.VarChar(80)
  /// Archivo en carpeta images/ (ej. logo.png). Vacío = buscar logo.png por defecto.
  logoArchivo                String?  @map("logo_archivo") @db.VarChar(120)
  textoGraciasTicket         String   @default("Gracias por su visita") @map("texto_gracias_ticket") @db.VarChar(200)
  textoPropinaTicket         String   @default("*** PROPINA VOLUNTARIA ***") @map("texto_propina_ticket") @db.VarChar(120)
  textoAvisoNoDian           String   @default("No constituye factura electrónica DIAN") @map("texto_aviso_no_dian") @db.VarChar(255)
  textoPieCorreo             String?  @map("texto_pie_correo") @db.Text
  prefijoAsuntoCorreo        String?  @map("prefijo_asunto_correo") @db.VarChar(80)
  mostrarCreditoDrewTech     Boolean  @default(true) @map("mostrar_credito_drewtech")
  etiquetaDescuentoSopas     String   @default("Descuento sopas") @map("etiqueta_descuento_sopas") @db.VarChar(80)
  etiquetaDescuentoMuleros   String   @default("Descuento clientes especiales") @map("etiqueta_descuento_muleros") @db.VarChar(80)
  moduloInventarioActivo     Boolean  @default(false) @map("modulo_inventario_activo")
  moduloMeserosOperativosActivo Boolean @default(true) @map("modulo_meseros_operativos_activo")
  moduloEnvioCorreoActivo    Boolean  @default(false) @map("modulo_envio_correo_activo")
  moduloResumenDiarioActivo  Boolean  @default(true) @map("modulo_resumen_diario_activo")
  actualizadoEn              DateTime @updatedAt @map("actualizado_en")

  @@map("config_restaurante")
}

/// Personalización visual: colores, iconos de navegación y assets gráficos.
model ConfigVisual {
  id                 Int      @id @default(1)
  colorPrimary       String?  @map("color_primary") @db.VarChar(7)
  colorPrimaryDark   String?  @map("color_primary_dark") @db.VarChar(7)
  colorSecondary     String?  @map("color_secondary") @db.VarChar(7)
  colorBackground    String?  @map("color_background") @db.VarChar(7)
  colorBackgroundAlt String?  @map("color_background_alt") @db.VarChar(7)
  colorSurface       String?  @map("color_surface") @db.VarChar(7)
  colorText          String?  @map("color_text") @db.VarChar(7)
  colorTextMuted     String?  @map("color_text_muted") @db.VarChar(7)
  colorBorder        String?  @map("color_border") @db.VarChar(7)
  logoLoginArchivo   String?  @map("logo_login_archivo") @db.VarChar(120)
  logoFacturaArchivo String?  @map("logo_factura_archivo") @db.VarChar(120)
  logoTicketArchivo  String?  @map("logo_ticket_archivo") @db.VarChar(120)
  faviconArchivo     String?  @map("favicon_archivo") @db.VarChar(120)
  navbarFondoArchivo String?  @map("navbar_fondo_archivo") @db.VarChar(120)
  /// Mapa clave nav → nombre Ionicons (JSON).
  iconosNav          Json?    @map("iconos_nav")
  /// Mapa clave acción → nombre Ionicons (JSON).
  iconosAccion       Json?    @map("iconos_accion")
  /// minimalista | profesional | calido | expresivo
  estiloVisual       String?  @default("minimalista") @map("estilo_visual") @db.VarChar(20)
  /// rectangular | redonda | cuadrada | barra
  mesaForma          String?  @map("mesa_forma") @db.VarChar(20)
  /// cuadricula | compacta | lista
  mesaVista          String?  @map("mesa_vista") @db.VarChar(20)
  actualizadoEn      DateTime @updatedAt @map("actualizado_en")

  @@map("config_visual")
}

/// Toggles de acciones para el rol chef (singleton id = 1).
model PermisosChefConfig {
  id                Int     @id @default(1)
  verColaCocina     Boolean @default(true) @map("ver_cola_cocina")
  marcarListo       Boolean @default(true) @map("marcar_listo")
  reimprimirComanda Boolean @default(true) @map("reimprimir_comanda")
  anularLineaCocina Boolean @default(true) @map("anular_linea_cocina")

  @@map("permisos_chef_config")
}

/// Toggles globales de acciones permitidas al rol mesero (singleton id=1).
model PermisosMeseroConfig {
  id                  Int     @id @default(1)
  agregarItems        Boolean @default(true) @map("agregar_items")
  editarCantidades    Boolean @default(true) @map("editar_cantidades")
  quitarLineas        Boolean @default(true) @map("quitar_lineas")
  enviarCocina        Boolean @default(true) @map("enviar_cocina")
  reimprimirComanda   Boolean @default(true) @map("reimprimir_comanda")
  cobrar              Boolean @default(true) @map("cobrar")
  precuenta           Boolean @default(true) @map("precuenta")
  reimprimirFactura   Boolean @default(true) @map("reimprimir_factura")
  cancelarPedido      Boolean @default(true) @map("cancelar_pedido")
  transferirMesa      Boolean @default(true) @map("transferir_mesa")
  ayudaCompaneros     Boolean @default(true) @map("ayuda_companeros")

  @@map("permisos_mesero_config")
}

/// Un mesero designado por día para cerrar mesa anulando lo pendiente (solo uno por fecha).
model DelegacionMeseroTurno {
  idRegistro        Int                   @id @default(autoincrement()) @map("id_registro")
  fecha             DateTime              @db.Date @map("fecha")
  tipo              TipoDelegacionMesero  @map("tipo")
  idUsuario         Int                   @map("id_usuario")
  idUsuarioRegistro Int                   @map("id_usuario_registro")
  creadoEn          DateTime              @default(now()) @map("creado_en")
  mesero            Usuario               @relation("DelegacionMesero", fields: [idUsuario], references: [idUsuario])
  registradoPor     Usuario               @relation("DelegacionRegistradaPor", fields: [idUsuarioRegistro], references: [idUsuario])

  @@unique([fecha, tipo])
  @@index([fecha, idUsuario])
  @@map("delegacion_mesero_turno")
}

/// Movimientos de efectivo en caja (devoluciones, entradas y salidas manuales).
model MovimientoCaja {
  idMovimientoCaja Int                     @id @default(autoincrement()) @map("id_movimiento_caja")
  fecha            DateTime                @db.Date @map("fecha")
  tipo             TipoMovimientoCaja      @map("tipo")
  monto            Decimal                 @db.Decimal(12, 2)
  motivo           String?                 @db.Text
  metodoDevolucion MetodoDevolucionExceso? @map("metodo_devolucion")
  idFactura        Int?                    @map("id_factura")
  idPedido         Int?                    @map("id_pedido")
  idUsuario        Int                     @map("id_usuario")
  creadoEn         DateTime                @default(now()) @map("creado_en")
  pedido           Pedido?                 @relation(fields: [idPedido], references: [idPedido], onDelete: Cascade)
  factura          Factura?                @relation(fields: [idFactura], references: [idFactura], onDelete: SetNull)
  usuario          Usuario                 @relation(fields: [idUsuario], references: [idUsuario])

  @@index([fecha])
  @@index([idPedido])
  @@map("movimiento_caja")
}

/// Monto inicial de efectivo en caja al abrir el día (por fecha calendario Bogotá).
model CajaDiaria {
  idCajaDiaria            Int      @id @default(autoincrement()) @map("id_caja_diaria")
  fecha                   DateTime @unique @db.Date
  montoBaseEfectivo       Decimal  @map("monto_base_efectivo") @db.Decimal(12, 2)
  montoBaseCierreEfectivo Decimal? @map("monto_base_cierre_efectivo") @db.Decimal(12, 2)
  actualizadoEn           DateTime @updatedAt @map("actualizado_en")

  @@map("caja_diaria")
}

model Inventario {
  idInventario   Int             @id @default(autoincrement()) @map("id_inventario")
  ingrediente    String          @unique @db.VarChar(150)
  cantidadActual Decimal         @map("cantidad_actual") @db.Decimal(10, 3)
  unidad         String          @db.VarChar(20)
  cantidadMinima Decimal         @map("cantidad_minima") @db.Decimal(10, 3)
  movimientos    MovInventario[]

  @@map("inventario")
}

model MovInventario {
  idMov        Int                 @id @default(autoincrement()) @map("id_mov")
  idInventario Int                 @map("id_inventario")
  idPedido     Int?                @map("id_pedido")
  tipoMov      TipoMovInventario   @map("tipo_mov")
  cantidad     Decimal             @db.Decimal(10, 3)
  fecha        DateTime            @default(now())
  observacion  String?             @db.Text
  inventario   Inventario          @relation(fields: [idInventario], references: [idInventario])
  pedido       Pedido?             @relation(fields: [idPedido], references: [idPedido])

  @@map("mov_inventario")
}

model ReporteVenta {
  idReporte          Int      @id @default(autoincrement()) @map("id_reporte")
  fecha              DateTime @unique @db.Date
  totalPedidos       Int      @default(0) @map("total_pedidos")
  totalIngresos      Decimal  @default(0) @map("total_ingresos") @db.Decimal(12, 2)
  totalComensales    Int      @default(0) @map("total_comensales")
  productoMasVendido String?  @map("producto_mas_vendido") @db.VarChar(150)

  @@map("reporte_venta")
}
